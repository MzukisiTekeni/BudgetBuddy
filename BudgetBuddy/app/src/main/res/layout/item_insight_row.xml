<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:gravity="top"
    android:background="@drawable/bg_insight_item"
    android:padding="12dp" android:layout_marginBottom="8dp">
    <TextView android:id="@+id/tv_insight_emoji"
        android:layout_width="20dp" android:layout_height="20dp"
        android:gravity="center" android:textSize="12sp"
        android:layout_marginEnd="8dp"/>
    <TextView android:id="@+id/tv_insight_text"
        android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="12sp" android:textColor="@color/text_secondary"
        android:lineSpacingMultiplier="1.3"/>
</LinearLayout>
