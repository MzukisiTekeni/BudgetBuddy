<?xml version="1.0" encoding="utf-8"?>
<!--
    item_settings_row.xml
    Reusable settings list row.
    Set tv_setting_label, tv_setting_value, and switch_toggle / iv_setting_action visibility from code.
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tv_setting_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Setting"
        android:textSize="@dimen/text_body"
        android:textColor="@color/text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/tv_setting_value"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tv_setting_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="@dimen/text_sm"
        android:textColor="@color/text_hint"
        android:visibility="gone"
        app:layout_constraintEnd_toStartOf="@id/iv_setting_action"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/iv_setting_action"
        android:layout_width="@dimen/icon_md"
        android:layout_height="@dimen/icon_md"
        android:src="@drawable/ic_chevron_right"
        android:contentDescription="Navigate"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
